{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "types": ["cypress", "node", "cypress-axe"],
    "strict": true,
    "skipLibCheck": true // Skip type checking of declaration files
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"] // Exclude node_modules to avoid external type issues
}
